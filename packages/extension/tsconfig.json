{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "~/*": ["./src/*"]
    },
    "outDir": "dist",
    "noEmit": true
  },
  "include": ["src/**/*", "*.ts"]
}
